          "auth": "JWT + Admin",
          "pathParams": {
            "id": "MongoDB ObjectId of product"
          },
          "note": "Product disappears from all public routes. Order history still references it correctly.",
          "responseSuccess": {
            "success": true,
            "message": "Product deactivated"
          }
        },
