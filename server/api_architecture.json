        {
          "id": "admin_orders_status",
          "method": "PUT",
          "url": "/api/v1/admin/orders/:id/status",
          "description": "Update order status — processing, shipping, delivery",
          "auth": "JWT + Admin",
          "pathParams": {
            "id": "Order ID (ORD_...)"
          },
          "allowedStatusFlow": "PENDING → PAID → PROCESSING → SHIPPED → DELIVERED | CANCELLED",
          "requestBody": {
            "status": "string (required — see allowedStatusFlow)",
            "trackingId": "string (optional — for SHIPPED status)",
            "note": "string (optional — internal note)"
          },
          "requestExample": {
            "status": "SHIPPED",
            "trackingId": "DTDC1234567890",
            "note": "Dispatched from Gurugram warehouse"
          },
          "responseSuccess": {
            "success": true,
            "message": "Order status updated to SHIPPED",
            "data": {
              "_id": "ORD_20260613_001",
              "status": "SHIPPED",
              "trackingId": "DTDC1234567890"
            }
          },
          "responseErrors": {
            "400": "Invalid status transition",
            "404": "Order not found"
          }
        },
        {
          "id": "admin_users_all",
          "method": "GET",
          "url": "/api/v1/admin/users",
          "description": "Get all registered users",
          "auth": "JWT + Admin",
          "security": "password field NEVER returned — Mongoose select('-password')",
          "queryParams": {
            "page": "number (default: 1)",
            "limit": "number (default: 50)",
            "search": "string (searches name, email)",
            "isBlocked": "boolean"
          },
          "responseSuccess": {
            "success": true,
            "data": {
              "users": [
                {
                  "_id": "uid_xyz",
                  "name": "Anand Sharma",
                  "email": "anand@email.com",
                  "phone": "9876543210",
                  "role": "user",
                  "isBlocked": false,
                  "ordersCount": 3,
                  "totalSpent": 5200,
                  "createdAt": "2026-01-01T00:00:00Z"
                }
              ],
              "pagination": {
                "total": 1240,
                "page": 1,
                "limit": 50
              }
            }
          }
        },
        {
          "id": "admin_users_block",
          "method": "PUT",
          "url": "/api/v1/admin/users/:id/block",
          "description": "Block or unblock a user account",
          "auth": "JWT + Admin",
          "pathParams": {
            "id": "MongoDB ObjectId of user"
          },
          "requestBody": {
            "isBlocked": "boolean (required)"
          },
          "requestExample": {
            "isBlocked": true
          },
          "note": "JWT middleware checks isBlocked on every protected request — blocked users instantly get 403",
          "responseSuccess": {
            "success": true,
            "message": "User blocked successfully"
          }
        },
        {
          "id": "admin_analytics_revenue",
